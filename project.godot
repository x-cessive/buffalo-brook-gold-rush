config_version=5

[application]

config/name="Buffalo Brook Gold Rush"
config/icon="res://icon.png"
run/main_scene="res://scenes/menu.tscn"
config/version="1.0.0"
config/copyright="2023 Your Company"
config/min_platform_version_android=1
config/macos_app_category="public.app-category.games"
config/file_associations={}
config/export_cache_mode=2
run/disable_stdout=false
run/disable_stderr=false

[debug]

